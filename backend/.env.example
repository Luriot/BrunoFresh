OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b-instruct
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SCRAPE_CONCURRENCY_LIMIT=1
# Required in production: set a strong random secret (≥32 chars)
# AUTH_SECRET=change-me-to-a-very-long-random-string
# Separate secret for session cookies (defaults to AUTH_SECRET if not set)
# SESSION_SECRET=another-very-long-random-string
# Enable HTTPS-only auth cookies in production:
# AUTH_COOKIE_SECURE=true
