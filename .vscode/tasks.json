{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Start Backend (FastAPI)",
      "type": "shell",
      "command": ".\\venv\\Scripts\\python.exe -m uvicorn app.main:app --reload",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "presentation": {
        "group": "brunofresh",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "🎨 Start Frontend (React)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "presentation": {
        "group": "brunofresh",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "🔥 START BRUNOFRESH (All)",
      "dependsOn": ["🚀 Start Backend (FastAPI)", "🎨 Start Frontend (React)"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
